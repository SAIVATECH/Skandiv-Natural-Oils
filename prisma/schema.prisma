generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  whatsappNumber String             @unique @map("whatsapp_number")
  name           String?
  email          String?            @unique
  password       String?
  role           Role               @default(CUSTOMER)
  createdAt      DateTime           @default(now()) @map("created_at")
  state          ConversationState?
  orders         Order[]
  campaignRecipients CampaignRecipient[]

  @@map("users")
}

model Product {
  id          String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  slug        String      @unique
  description String
  price       Decimal     @db.Decimal(10, 2)
  mrp         Decimal?    @db.Decimal(10, 2)
  stock       Int
  imageUrl    String      @map("image_url")
  category    String
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  items       OrderItem[]

  @@map("products")
}

model Order {
  id                String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId            String        @map("user_id")
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  orderStatus       OrderStatus   @default(PENDING) @map("order_status")
  trackingUrl       String?       @map("tracking_url")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  shippingAddress   String?       @map("shipping_address")
  createdAt         DateTime      @default(now()) @map("created_at")
  items             OrderItem[]
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model ConversationState {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId            String   @unique @map("user_id")
  currentStep       String   @default("START") @map("current_step")
  selectedProductId String?  @map("selected_product_id")
  quantity          Int?
  pendingOrderId    String?  @map("pending_order_id")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversation_state")
}

model Payment {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId           String   @map("order_id")
  razorpayPaymentId String   @map("razorpay_payment_id")
  amount            Decimal  @db.Decimal(10, 2)
  status            String
  createdAt         DateTime @default(now()) @map("created_at")
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model MessageLog {
  id        String   @id
  sender    String
  phone     String
  text      String
  timestamp DateTime @default(now())

  @@map("message_logs")
}

model Campaign {
  id               String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  name             String
  description      String?
  status           CampaignStatus      @default(DRAFT)
  templateName     String              @map("template_name")
  templateLanguage String              @map("template_language")
  templateVariables Json               @map("template_variables")
  scheduledAt      DateTime?           @map("scheduled_at")
  startedAt        DateTime?           @map("started_at")
  completedAt      DateTime?           @map("completed_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  recipients       CampaignRecipient[]
  logs             CampaignLog[]

  @@map("campaigns")
}

model CampaignRecipient {
  id           String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  campaignId   String          @map("campaign_id")
  customerId   String          @map("customer_id")
  status       RecipientStatus @default(PENDING)
  sentAt       DateTime?       @map("sent_at")
  deliveredAt  DateTime?       @map("delivered_at")
  readAt       DateTime?       @map("read_at")
  failedAt     DateTime?       @map("failed_at")
  errorMessage String?         @map("error_message")
  retryCount   Int             @default(0) @map("retry_count")
  wamid        String?         @unique
  cost         Decimal?        @db.Decimal(10, 4)
  variables    Json?
  campaign     Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer     User            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
  @@index([wamid])
  @@index([status])
  @@map("campaign_recipients")
}

model CampaignTemplate {
  id           String   @id
  name         String   @unique
  language     String
  category     String
  status       String
  components   Json
  lastSyncedAt DateTime @default(now()) @map("last_synced_at")

  @@map("campaign_templates")
}

model CampaignLog {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  campaignId String   @map("campaign_id")
  level      String
  message    String
  timestamp  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_logs")
}

model CampaignSettings {
  id                      String   @id @default("global")
  dailyCap                Int      @default(1000) @map("daily_cap")
  monthlyCap              Int      @default(30000) @map("monthly_cap")
  campaignRateLimitPerMin Int      @default(60) @map("campaign_rate_limit_per_min")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("campaign_settings")
}

model CampaignAuditLog {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String   @map("user_id")
  action    String
  details   String?
  timestamp DateTime @default(now())

  @@map("campaign_audit_logs")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  PAUSED
  CANCELLED
}

enum RecipientStatus {
  PENDING
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}
